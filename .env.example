# === SERVER ===
PORT=3000
ADMIN_PASS=sua_senha_admin_aqui

# === GEMINI API KEYS (até 30 chaves com rotação automática) ===
GEMINI_KEY_1=AIza...
GEMINI_KEY_2=AIza...
